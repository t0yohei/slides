{
  "rewrites": [
    { "source": "/rails-omae-datta-no-ka", "destination": "/rails-omae-datta-no-ka/" },
    { "source": "/rails-omae-datta-no-ka/(.*)", "destination": "/rails-omae-datta-no-ka/index.html" },
    { "source": "/test-slide", "destination": "/test-slide/" },
    { "source": "/test-slide/(.*)", "destination": "/test-slide/index.html" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "buildCommand": "npm run build:all",
  "outputDirectory": "dist"
}
